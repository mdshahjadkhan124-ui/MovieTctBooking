# Render sets this automatically in production — leave blank locally to
# default to 5000, or set it to match your local setup.
PORT=

# MongoDB Atlas (or any reachable Mongo) connection string.
MONGO_URI=

# Redis connection string. Use rediss:// (not redis://) for a TLS-only
# provider like Upstash — the redis client auto-enables TLS from the scheme.
REDIS_URL=

# "development" locally; set to "production" on Render. Controls cookie
# sameSite/secure flags and whether CORS requires CLIENT_URL to be set.
NODE_ENV=

# The deployed frontend's exact origin (e.g. https://your-app.vercel.app).
# Required in production — CORS will refuse to start without it.
CLIENT_URL=

JWT_SECRET=
JWT_EXPIRES_IN=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Stripe test-mode (or live) secret key.
STRIPE_SECRET_KEY=

# From the Stripe CLI (`stripe listen`) locally, or the dashboard's webhook
# endpoint secret in production.
STRIPE_WEBHOOK_SECRET=
